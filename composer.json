{
  "name": "motor-cms/motor-backend",
  "version": "1.3.3",
  "description": "Motor backend package - Laravel 12 compatible",
  "license": "MIT",
  "keywords": [
    "motor"
  ],
  "authors": [
    {
      "name": "Reza Esmaili",
      "email": "me@dfox.info"
    }
  ],
  "require": {
    "darkaonline/l5-swagger": "^8.0",
    "guzzlehttp/guzzle": "^7.0",
    "kalnoy/nestedset": "^6.0",
    "kra8/laravel-snowflake": "^v2.3",
    "kris/laravel-form-builder": "^1.40",
    "laracasts/flash": "^3.0",
    "laravel/horizon": "^5.0",
    "laravel/ui": "^4.0",
    "lavary/laravel-menu": "^1.8",
    "librenms/laravel-vue-i18n-generator": "dev-master",
    "motor-cms/motor-core": "^1.2",
    "php": "^8.2",
    "php-console/php-console": "^3.1",
    "spatie/laravel-fractal": "^6.0",
    "spatie/laravel-html": "^3.5",
    "spatie/laravel-medialibrary": "^11.0",
    "spatie/laravel-permission": "^6.0",
    "symfony/intl": "^6.0|^7.0",
    "symfony/mailgun-mailer": "^6.0|^7.0",
    "tightenco/ziggy": "^1.0",
    "wildside/userstamps": "^4.0"
  },
  "require-dev": {
    "barryvdh/laravel-ide-helper": "^3.0",
    "symfony/css-selector": "^6.0|^7.0",
    "symfony/dom-crawler": "^6.0|^7.0",
    "laravel/dusk": "^8.0"
  },
  "autoload": {
    "psr-4": {
      "Motor\\Backend\\": "src",
      "Tests\\Motor\\Backend\\": "tests",
      "Motor\\Backend\\Database\\Factories\\": "database/factories/",
      "Motor\\Backend\\Database\\Seeders\\": "database/seeders/"
    },
    "files": [
      "helpers/motor_backend_helpers.php"
    ]
  },
  "extra": {
    "laravel": {
      "providers": [
        "Motor\\Backend\\Providers\\MotorServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
